<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <!-- Заголовок -->
    <TextView
        android:id="@+id/tvCardTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Название карточки"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Прогресс -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 / 10"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@+id/tvCardTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Кнопка для смены стороны Вопрос/Ответ -->
    <Button
        android:id="@+id/btnToggleSide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Вопрос"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_marginTop="4dp"
        android:backgroundTint="@color/blue"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@+id/tvProgress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Контейнер для стороны "Вопрос" -->
    <ScrollView
        android:id="@+id/questionScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="visible"
        android:background="#FFFFFF"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@+id/btnToggleSide"
        app:layout_constraintBottom_toTopOf="@+id/btnNextCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/questionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />

    </ScrollView>

    <!-- Контейнер для стороны "Ответ" -->
    <ScrollView
        android:id="@+id/answerScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#FFFFFF"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@+id/btnToggleSide"
        app:layout_constraintBottom_toTopOf="@+id/btnNextCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/answerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />

    </ScrollView>

    <!-- Кнопка следующей карточки -->
    <Button
        android:id="@+id/btnNextCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Следующая карточка →"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:layout_margin="12dp"
        android:backgroundTint="@color/blue"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>